# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
*.egg-info/
dist/
build/

# --- Virtual environments ---
venv/
.venv/
env/
.env

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Docker ---
# Don't ignore Dockerfile or docker-compose.yml

# --- Uploads (runtime data, not source code) ---
uploads/

# --- Logs ---
*.log
